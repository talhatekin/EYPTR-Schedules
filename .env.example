# --- Depolama: Vercel Marketplace > Upstash (Redis) ---
# Vercel'de Redis entegrasyonu eklediğinde bu iki değişken otomatik gelir.
# Yerel geliştirmede Upstash panelinden kopyalayabilirsin.
# (UPSTASH_REDIS_REST_URL / UPSTASH_REDIS_REST_TOKEN adları da desteklenir.)
KV_REST_API_URL=
KV_REST_API_TOKEN=

# --- Admin panel şifresi ---
# Ayarlanmazsa güvensiz varsayılan "123" kullanılır — MUTLAKA değiştir.
ADMIN_SECRET_PASSWORD=
